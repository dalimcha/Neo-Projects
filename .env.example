# India Terminal — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Features (optional but recommended) ────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Daily Email Briefs (optional) ─────────────────────────────────────────────
# For Gmail: use App Passwords (not your main password)
# Enable 2FA first, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Brief delivery times (IST, 24-hour format)
MORNING_TIME=08:30
EVENING_TIME=16:30
